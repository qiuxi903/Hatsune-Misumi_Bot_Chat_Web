# 服务器配置
PORT=5000
NODE_ENV=development

# JWT配置 - 请修改为随机生成的强密钥
JWT_SECRET=your_jwt_secret_here

# 数据库配置
DB_PATH=./database/chat.db

# AstrBot配置
ASTRBOT_API_URL=http://localhost:6185
ASTRBOT_API_KEY=your_astrbot_api_key_here

# 连接方式选择：http 或 websocket
# http - 使用AstrBot HTTP API（推荐，更稳定）
# websocket - 使用OneBot v11反向WebSocket
CONNECTION_MODE=websocket

# OneBot v11配置（反向WebSocket连接到AstrBot）
# 仅在 CONNECTION_MODE=websocket 时生效
ONEBOT_WS_URL=ws://localhost:6199/ws
ONEBOT_TOKEN=your_onebot_token_here

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS配置
CORS_ORIGIN=http://localhost:3000
